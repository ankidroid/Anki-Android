<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/background"
        android:scaleType="centerCrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:id="@+id/deckpicker_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" >

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/pull_to_sync_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <RelativeLayout
                    android:id="@+id/deck_picker_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/decks"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:drawSelectorOnTop="true"
                        android:fastScrollEnabled="true"
                        android:focusable="true"
                        android:paddingBottom="72dp"
                        android:layout_above="@id/review_summary_text_view"
                        android:scrollbars="vertical" />

                    <com.ichi2.ui.FixedTextView
                        android:id="@+id/review_summary_text_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentStart="true"
                        android:layout_marginHorizontal="@dimen/ads_spacing_sm"
                        android:layout_marginBottom="@dimen/ads_spacing_xs"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.Anki.BodySmall"
                        android:textColor="?attr/adsMutedForeground" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/no_decks_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:layout_gravity="center_horizontal"
                        app:srcCompat="@drawable/anki_box" />

                    <com.ichi2.ui.FixedTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ads_spacing_sm"
                        android:gravity="center"
                        android:text="@string/no_cards_placeholder_title"
                        android:textAppearance="@style/TextAppearance.Anki.TitleMedium"
                        android:textColor="?attr/adsForeground" />

                    <com.ichi2.ui.FixedTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ads_spacing_xl"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/ads_spacing_xl"
                        android:text="@string/no_cards_placeholder_description"
                        android:textAlignment="center"
                        android:textAppearance="@style/TextAppearance.Anki.BodyMedium"
                        android:textColor="?attr/adsMutedForeground" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/empty_state_add_deck_button"
                        style="@style/Widget.Anki.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/new_deck"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

            </FrameLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <include layout="@layout/include_anki_progress"/>
    <include
        android:id="@+id/floating_action_button"
        layout="@layout/include_floating_add_button"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
