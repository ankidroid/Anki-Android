<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/studyoptions_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/adsBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/studyoptions_gradient"
            android:layout_width="15dp"
            android:layout_height="0dp"
            android:background="@drawable/shadow_left"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/studyoptions_start"
            style="@style/Widget.Anki.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/ads_spacing_2xl"
            android:minWidth="200dp"
            android:text="@string/studyoptions_start"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ScrollView
            android:id="@+id/studyoptions_scrollview"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fadeScrollbars="false"
            android:paddingStart="@dimen/ads_spacing_sm"
            android:paddingEnd="@dimen/ads_spacing_sm"
            android:paddingBottom="@dimen/ads_spacing_lg"
            app:layout_constraintBottom_toTopOf="@id/studyoptions_start"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/studyoptions_gradient"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/studyoptions_scrollcontainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="@dimen/ads_spacing_lg">

                <com.ichi2.ui.FixedTextView
                    android:id="@+id/studyoptions_deck_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="3"
                    android:textAppearance="@style/TextAppearance.Anki.TitleLarge"
                    android:textColor="?attr/adsForeground"
                    tools:text="Deck name here" />

                <com.ichi2.ui.FixedTextView
                    android:id="@+id/studyoptions_bury_counts_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Anki.BodySmall"
                    android:textColor="?attr/adsMutedForeground"
                    android:visibility="gone"
                    tools:text="Counts differ" />

                <LinearLayout
                    android:id="@+id/group_counts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ads_spacing_lg"
                    android:orientation="vertical">

                <!-- New / Learning / Review stat cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Anki.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/ads_spacing_xs"
                        android:layout_weight="1"
                        app:strokeColor="?attr/adsAccent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/studyoptions_new_count_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Anki.StatLabel"
                                tools:text="New:" />

                            <TextView
                                android:id="@+id/studyoptions_new_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatValue"
                                android:textColor="?attr/newCountColor"
                                tools:text="88" />

                            <TextView
                                android:id="@+id/studyoptions_new_bury"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatBury"
                                android:textColor="?attr/buryCountColor"
                                android:visibility="gone"
                                tools:text="+4 buried"
                                tools:visibility="visible" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Anki.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/ads_spacing_xs"
                        android:layout_weight="1"
                        app:strokeColor="?attr/adsDestructive">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/studyoptions_learning_count_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Anki.StatLabel"
                                tools:text="Learning:" />

                            <TextView
                                android:id="@+id/studyoptions_learning_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatValue"
                                android:textColor="?attr/learnCountColor"
                                tools:text="3" />

                            <TextView
                                android:id="@+id/studyoptions_learning_bury"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatBury"
                                android:textColor="?attr/buryCountColor"
                                android:visibility="gone"
                                tools:text="+23 buried"
                                tools:visibility="visible" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Anki.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/ads_spacing_xs"
                        android:layout_weight="1"
                        app:strokeColor="?attr/adsGoodColor">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/studyoptions_review_count_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Anki.StatLabel"
                                tools:text="To Review:" />

                            <TextView
                                android:id="@+id/studyoptions_review_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatValue"
                                android:textColor="?attr/reviewCountColor"
                                tools:text="104" />

                            <TextView
                                android:id="@+id/studyoptions_review_bury"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/ads_spacing_xs"
                                android:textAppearance="@style/TextAppearance.Anki.StatBury"
                                android:textColor="?attr/buryCountColor"
                                android:visibility="gone"
                                tools:text="+20 buried"
                                tools:visibility="visible" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Deck totals -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Anki.StatCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ads_spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/ads_spacing_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/studyoptions_total_new_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/studyoptions_total_new_label"
                                android:textAppearance="@style/TextAppearance.Anki.StatLabel" />

                            <TextView
                                android:id="@+id/studyoptions_total_new_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Anki.BodyLarge"
                                android:textColor="?attr/adsForeground"
                                tools:text="16597" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/ads_border_width"
                            android:layout_marginVertical="@dimen/ads_spacing_sm"
                            android:background="?attr/adsBorder" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/studyoptions_total_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/studyoptions_total_label"
                                android:textAppearance="@style/TextAppearance.Anki.StatLabel" />

                            <TextView
                                android:id="@+id/studyoptions_total_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Anki.BodyLarge"
                                android:textColor="?attr/adsForeground"
                                tools:text="22177" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.ichi2.ui.FixedTextView
                    android:id="@+id/studyoptions_deck_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/ads_spacing_lg"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/ads_spacing_sm"
                    android:textAppearance="@style/TextAppearance.Anki.BodyMedium"
                    android:textColor="?attr/adsMutedForeground"
                    tools:text="See shared deck for more info" />

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include layout="@layout/include_anki_progress" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
