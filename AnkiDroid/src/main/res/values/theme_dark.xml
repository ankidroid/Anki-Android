<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="DuplicateCrowdInStrings">
    <color name="theme_dark_primary">@color/ads_dark_background</color>
    <color name="theme_dark_primary_dark">@color/ads_dark_background</color>
    <color name="theme_dark_primary_light">@color/ads_dark_surface_elevated</color>
    <color name="theme_dark_primary_text">@color/ads_dark_foreground</color>
    <color name="theme_dark_secondary_text">@color/ads_dark_muted_foreground</color>
    <color name="theme_dark_row_current">@color/ads_dark_surface_elevated</color>
    <color name="theme_dark_drawer_row_current">#33999999</color>
    <color name="theme_dark_drawer_item">#DEFFFFFF</color>

    <style name="Base.Theme.Dark" parent="@style/Theme.Material3.Dark.NoActionBar">
        <!-- Anki Design System tokens -->
        <item name="adsBackground">@color/ads_dark_background</item>
        <item name="adsSurface">@color/ads_dark_surface</item>
        <item name="adsSurfaceElevated">@color/ads_dark_surface_elevated</item>
        <item name="adsBorder">@color/ads_dark_border</item>
        <item name="adsForeground">@color/ads_dark_foreground</item>
        <item name="adsMutedForeground">@color/ads_dark_muted_foreground</item>
        <item name="adsAccent">@color/ads_dark_accent</item>
        <item name="adsAccentMuted">@color/ads_dark_accent_muted</item>
        <item name="adsDestructive">@color/ads_dark_destructive</item>
        <item name="adsDestructiveMuted">@color/ads_dark_destructive_muted</item>
        <item name="adsGoodColor">@color/ads_dark_good</item>
        <item name="adsGoodMuted">@color/ads_dark_good_muted</item>
        <item name="adsHardColor">@color/ads_dark_hard</item>
        <item name="adsHardMuted">@color/ads_dark_hard_muted</item>
        <item name="adsEasyColor">@color/ads_dark_easy</item>
        <item name="adsEasyMuted">@color/ads_dark_easy_muted</item>
        <item name="adsPopupBackground">@color/ads_dark_popup</item>
        <item name="adsRipple">@color/ads_dark_ripple</item>
        <item name="adsDeckRowSelected">@drawable/ads_ripple_deck_selected</item>

        <!-- Android colors -->
        <item name="colorPrimary">@color/ads_dark_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/ads_dark_background</item>
        <item name="colorSurface">@color/ads_dark_surface</item>
        <item name="colorAccent">@color/ads_dark_accent</item>
        <item name="colorOnSurface">@color/ads_dark_foreground</item>
        <item name="colorPrimaryContainer">@color/white</item> <!-- Switch thumb color when disabled and being pressed -->
        <item name="colorOnPrimaryContainer">@color/white</item> <!-- FAB icons -->

        <item name="android:textColor">@color/text_color_dark</item>
        <item name="android:textColorSecondary">@color/text_color_secondary_dark</item>
        <item name="android:colorBackground">@color/ads_dark_background</item>
        <item name="android:windowBackground">@color/ads_dark_background</item>
        <item name="colorSecondaryContainer">@color/ads_dark_accent_muted</item>
        <item name="colorOnSecondaryContainer">@color/ads_dark_foreground</item>

        <item name="colorSurfaceContainerHighest">@color/ads_dark_surface_elevated</item>
        <item name="colorSurfaceContainerHigh">@color/ads_dark_surface_elevated</item>
        <item name="colorSurfaceContainer">@color/ads_dark_surface</item>
        <item name="colorSurfaceContainerLow">@color/ads_dark_background</item>
        <!-- Widget colors -->
        <item name="widgetColorActivated">?attr/colorAccent</item>
        <item name="preferenceCategoryTitleTextColor">?attr/colorAccent</item>
        <!-- Navigation drawer -->
        <item name="navDrawerItemColor">@color/drawer_item_text_dark</item>
        <item name="navDrawerItemBackgroundColor">@drawable/drawer_item_background_dark</item>
        <!-- Menu -->
        <item name="actionOverflowMenuStyle">@style/OverflowMenuStyle</item>
        <item name="popupMenuStyle">@style/PopupMenuStyle</item>
        <item name="spinnerStyle">@style/SpinnerStyle</item>
        <!-- Action bar styles -->
        <item name="appBarColor">@color/ads_dark_background</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="actionBarTextColor">@color/ads_dark_foreground</item>
        <item name="actionBarPopupTextColor">@color/theme_dark_primary_text</item>
        <item name="actionModeBackground">@color/theme_dark_primary</item>
        <!-- Tab layout -->
        <item name="tabLayoutBackgroundColor">@color/ads_dark_background</item>
        <item name="tabActiveIconColor">@color/ads_dark_accent</item>
        <!-- Deck list colors and divider -->
        <item name="currentDeckBackground">@drawable/ads_ripple_deck_selected</item>
        <item name="currentDeckBackgroundColor">@color/ads_dark_surface_elevated</item>
        <item name="focusedRowBackgroundColor">@color/ads_dark_surface_elevated</item>
        <item name="dynDeckColor">@color/ads_dark_accent</item>
        <item name="deckDivider">@drawable/divider_dark</item>
        <item name="expandRef">@drawable/ic_chevron_right_white</item>
        <item name="collapseRef">@drawable/ic_expand_more_white</item>
        <!-- Count colors -->
        <item name="newCountColor">@color/ads_dark_accent</item>
        <item name="learnCountColor">@color/ads_dark_destructive</item>
        <item name="reviewCountColor">@color/ads_dark_good</item>
        <item name="buryCountColor">@color/ads_dark_muted_foreground</item>
        <item name="zeroCountColor">@color/ads_dark_border</item>
        <!-- Study Screen colors -->
        <item name="showAnswerButtonBackground">@color/ads_dark_accent</item>
        <item name="againButtonBackground">@color/ads_dark_destructive_muted</item>
        <item name="hardButtonBackground">@color/ads_dark_hard_muted</item>
        <item name="goodButtonBackground">@color/ads_dark_good_muted</item>
        <item name="easyButtonBackground">@color/ads_dark_easy_muted</item>
        <item name="topBarColor">@color/ads_dark_background</item>
        <item name="maxTimerColor">@color/ads_dark_destructive</item>
        <item name="answerButtonTextColor">@color/ads_dark_foreground</item>
        <item name="againButtonTextColor">@color/ads_dark_destructive</item>
        <item name="hardButtonTextColor">@color/ads_dark_hard</item>
        <item name="goodButtonTextColor">@color/ads_dark_good</item>
        <item name="easyButtonTextColor">@color/ads_dark_easy</item>

        <item name="alternativeBackgroundColor">@color/ads_dark_surface</item>
        <item name="againTextColor">@color/ads_dark_destructive</item>
        <item name="hardTextColor">@color/ads_dark_hard</item>
        <item name="goodTextColor">@color/ads_dark_good</item>
        <item name="easyTextColor">@color/ads_dark_easy</item>
        <item name="againBackgroundColor">@color/ads_dark_destructive_muted</item>
        <item name="hardBackgroundColor">@color/ads_dark_hard_muted</item>
        <item name="goodBackgroundColor">@color/ads_dark_good_muted</item>
        <item name="easyBackgroundColor">@color/ads_dark_easy_muted</item>
        <item name="againIconColor">?againTextColor</item>
        <item name="hardIconColor">?hardTextColor</item>
        <item name="goodIconColor">?goodTextColor</item>
        <item name="easyIconColor">?easyTextColor</item>
        <!-- Study Screen button drawables -->
        <item name="showAnswerColor">@color/material_blue_grey_800</item>
        <item name="againButtonRef">@drawable/footer_button_again_dark</item>
        <item name="hardButtonRef">@drawable/footer_button_hard_dark</item>
        <item name="goodButtonRef">@drawable/footer_button_good_dark</item>
        <item name="easyButtonRef">@drawable/footer_button_easy_dark</item>
        <item name="againButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="hardButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="goodButtonRippleRef">@drawable/footer_button_ripple</item>
        <item name="easyButtonRippleRef">@drawable/footer_button_ripple</item>
        <!-- Card Browser Colors -->
        <item name="cardBrowserDivider">@color/white</item>
        <!-- Browser colors -->
        <item name="suspendedColor">@color/material_grey_700</item>
        <item name="buriedColor">#612B09</item>
        <item name="markedColor">@color/material_deep_purple_400</item>
        <!-- Note editor colors -->
        <item name="duplicateColor">#855</item>
        <item name="editTextBackgroundColor">#EE5C5C5C</item>
        <item name="editTextHighlightColor">@color/material_light_blue_900</item>
        <item name="toolbarBackgroundColor">#616161</item>
        <item name="toolbarIconColor">@color/white</item>
        <item name="buttonShadowColor">#bdbdbd</item>
        <item name="buttonRippleColor">#BABABA</item>
        <item name="buttonForegroundColor">#757575</item>
        <!-- FAB -->
        <item name="fab_normal">@color/ads_dark_accent</item>
        <item name="fab_pressed">@color/ads_dark_accent_muted</item>
        <!-- Images -->
        <item name="navDrawerImage">@drawable/nav_drawer_logo_dark_theme</item>
        <!-- Dialog styles -->
        <item name="android:listPreferredItemHeight">56dip</item>
        <item name="dialogCornerRadius">@dimen/dialog_corner_radius</item>
        <item name="android:dialogCornerRadius" tools:targetApi="p">@dimen/dialog_corner_radius</item>
        <item name="textAllCaps">false</item>
        <item name="clozeColor">#1976D2</item>
        <!--Custom Tabs colors-->
        <item name="customTabNavBarColor">@color/material_grey_800</item>
        <item name="popupBackgroundColor">@color/ads_dark_popup</item>
        <item name="editTextDisabled">@color/ads_dark_muted_foreground</item>
        <item name="overflowAndPopupMenuIconColor">@color/ads_dark_foreground</item>
        <!-- StatusBar -->
        <item name="android:statusBarColor">@color/ads_dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Navbar -->
        <item name="android:navigationBarColor">@color/ads_dark_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Snackbar. Attributes snackbarStyle, snackbarTextViewStyle and snackbarButtonStyle
             must be *all* present in a theme (or its parent) in order for the snackbar
             to pick up the proper layout that uses these attributes. -->
        <item name="snackbarStyle">@style/SnackbarStyle</item>
        <item name="snackbarTextViewStyle">@style/Widget.MaterialComponents.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/SnackbarButtonStyle</item>
        <item name="snackbarBackgroundTintColor">@color/ads_dark_surface_elevated</item>
        <item name="snackbarButtonTextColor">@color/ads_dark_accent</item>

        <!-- Introduction -->
        <item name="introductionLogoTransparent">#883d3d3d</item>

        <!-- Widget styles -->
        <item name="switchPreferenceCompatStyle">@style/Preference.SwitchPreferenceCompat.Material3</item>
        <item name="sliderStyle">@style/SliderStyle</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.Anki</item>

        <!-- ProgressDialog-->
        <item name="dialogBackground">@color/ads_dark_surface_elevated</item>
        <item name="progressDialogButtonTextColor">@color/ads_dark_accent</item>

        <item name="alertDialogTheme">@style/ThemeOverlay.Anki.AlertDialog</item>
        <item name="checkMediaListBackground">@color/ads_dark_surface_elevated</item>
        <item name="checkMediaListForeground">@color/ads_dark_foreground</item>
        <item name="tabStyle">@style/Widget.MaterialComponents.TabLayout</item>

        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>

        <item name="incrementerButtonBackground">@color/ads_dark_surface_elevated</item>

        <!-- Reminder troubleshooting -->
        <item name="reminderTroubleshootingOk">@color/google_green_300</item>
        <item name="reminderTroubleshootingWarning">@color/google_yellow_300</item>
    </style>

    <style name="Theme_Dark" parent="Base.Theme.Dark"/>
</resources>
